# Swiish Environment Configuration
# Copy this file to .env and fill in your values

# === REQUIRED VARIABLES ===

# JWT Secret Key - Used for signing authentication tokens
# Generate a strong random string using: openssl rand -base64 32
JWT_SECRET=change-this-secret-in-production



# Node Environment - Set to 'production' for production deployments
# Default: development
NODE_ENV=development

# Demo Mode - ⚠️ DEVELOPMENT & DEMO ONLY - DO NOT USE IN PRODUCTION
# When enabled (true), bypasses authentication, seeds database with demo data,
# and resets all data every 60 minutes.
DEMO_MODE=false

# Server Port - Port for the Express server to listen on
# Default: 3000
PORT=3000

# JWT Expiration - How long JWT tokens remain valid
# Default: 24h (24 hours)
JWT_EXPIRES_IN=24h

# Allowed Origins - Comma-separated list of allowed CORS origins
# Default: http://localhost:3000,http://localhost:8095
# For production, set to your actual domain(s)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8095

# Max File Size - Maximum file upload size in bytes
# Default: 5242880 (5MB)
MAX_FILE_SIZE=5242880

# Force HTTPS - Set to 'true' to force HTTPS redirects in production
# Default: false
# Note: Usually handled by reverse proxy (nginx, Traefik) in production
FORCE_HTTPS=false

# Application URL - Base URL for the application
# Required in production mode, optional in development
# For Docker (port 8095): http://localhost:8095
# For local dev (port 3000): http://localhost:3000
# For production: https://yourdomain.com
APP_URL=http://localhost:8095

# === EMAIL CONFIGURATION (Optional) ===
# Configure SMTP settings to enable email features (invitations, password resets, etc.)
# If not configured, emails will be logged to console in development mode

# SMTP Host - Your SMTP server hostname
SMTP_HOST=

# SMTP Port - SMTP server port (usually 587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP Secure - Set to 'true' for SSL (port 465), 'false' for TLS (port 587)
SMTP_SECURE=false

# SMTP User - SMTP authentication username
SMTP_USER=

# SMTP Password - SMTP authentication password
SMTP_PASSWORD=

# SMTP From - Email address to send from (defaults to noreply@localhost if not set)
SMTP_FROM=

# ── Google Wallet (Android) ────────────────────────────────────────────────
# Optional. Leave blank to disable the "Add to Google Wallet" button.
#
# Setup (3 steps):
# 1. Go to Google Cloud Console → enable "Google Wallet API" → create a
#    Service Account → generate a JSON key (you need client_email + private_key)
# 2. Register as an issuer at https://pay.google.com/business/console
#    Sign in, accept terms → your Issuer ID appears in the console (numeric)
# 3. Add the 4 variables below — the server creates the pass class automatically

# Issuer ID from https://pay.google.com/business/console (numeric, e.g. 3388000000012345678)
GOOGLE_WALLET_ISSUER_ID=

# Suffix for the pass class — the server will create this class automatically on startup
GOOGLE_WALLET_CLASS_SUFFIX=business_card

# Service account email from your Google Cloud JSON key file (client_email field)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Service account private key (private_key field from JSON key — include full PEM with \n newlines)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

